# Base URL of the NestJS backend API (no trailing slash).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# Localization defaults (i18n-ready). Owner can change at runtime via the API.
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,bn
NEXT_PUBLIC_DEFAULT_CURRENCY=BDT

# ── Multi-tenant resolution ──────────────────────────────────────
# How the frontend tells the backend which tenant to resolve:
#   host = resolve by the incoming request host (production white-label).
#   slug = resolve by a fixed slug (local dev / single-tenant preview).
NEXT_PUBLIC_TENANT_MODE=host
# Used only when NEXT_PUBLIC_TENANT_MODE=slug.
NEXT_PUBLIC_TENANT_SLUG=
# Fallback theme key used when the resolve endpoint is unavailable or omits one.
# Known keys: default, bdbet21. Leave blank to use 'default'.
NEXT_PUBLIC_THEME_KEY=
